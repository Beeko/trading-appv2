# ─── Alpaca ───────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_PAPER=true

# ─── Live trading gate (ALL three must be set to enable live mode) ─────────────
# Set this to true ONLY when you are ready to trade real money
ALLOW_LIVE_TRADING=false

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=changeme_strong_password

# ─── Reddit WSB Scanner (optional — scanner falls back to watchlist if absent) ─
# Register a Reddit app at https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# REDDIT_USER_AGENT=TradingBot/1.0 by YourUsername

# ─── Internal (set automatically by docker-compose, do not change) ─────────────
# DATABASE_URL=postgresql+asyncpg://trader:${DB_PASSWORD}@db:5432/trading
